ENV=local
GCP_PROJECT_ID=replace-with-firebase-project-id
APP_HOST=0.0.0.0
APP_PORT=8000
APP_URL=https://sms.nasak.ir
APP_NAME=Nasak SMS
SWAGGER_HOST=sms.nasak.ir/api
USE_HTTP_LOGGER=false
DATABASE_DEBUG_LOGS=false
ENTITLEMENT_ENABLED=false
BILLING_LIMITS_ENABLED=false
PAID_FEATURES_ENABLED=false
CORS_ALLOW_ORIGINS=https://sms.nasak.ir
CORS_ALLOW_HEADERS=Authorization,Content-Type,X-Api-Key,X-Client-Version
CORS_ALLOW_METHODS=GET,POST,PUT,DELETE,OPTIONS
CORS_EXPOSE_HEADERS=Content-Disposition

DATABASE_URL=postgresql://httpsms:replace-password@postgres:5432/httpsms
DATABASE_URL_DEDICATED=postgresql://httpsms:replace-password@postgres:5432/httpsms
REDIS_URL=redis://redis:6379

EVENTS_QUEUE_TYPE=emulator
EVENTS_QUEUE_NAME=events-local
EVENTS_QUEUE_ENDPOINT=http://api:8000/v1/events
EVENTS_QUEUE_USER_ID=replace-with-random-uuid
EVENTS_QUEUE_USER_API_KEY=replace-with-long-random-api-key

# Compact, single-line service account JSON. Never commit the production value.
FIREBASE_CREDENTIALS=
# Optional same-origin email/password auth fallback proxy for restricted networks.
# Example: socks5://user:pass@host:port or http://user:pass@host:port
FIREBASE_AUTH_PROXY_URL=
# Optional referrer used when Firebase API keys are restricted by HTTP referrer.
FIREBASE_AUTH_REFERER_URL=https://sms.nasak.ir/
# Required for Nasak-hosted email/password fallback when Firebase is unreachable.
LOCAL_AUTH_SECRET=replace-with-at-least-32-random-bytes

SMTP_FROM_NAME=Nasak SMS
SMTP_FROM_EMAIL=no-reply@nasak.ir
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_HOST=
SMTP_PORT=587

GCS_BUCKET_NAME=
AXIOM_TOKEN=
AXIOM_DATASET_EVENTS=
AXIOM_DATASET_METRICS=
PUSHER_APP_ID=
PUSHER_KEY=
PUSHER_SECRET=
PUSHER_CLUSTER=
CLOUDFLARE_TURNSTILE_SECRET_KEY=
