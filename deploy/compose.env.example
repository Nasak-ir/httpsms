# This file contains public build configuration plus the database password used
# by Docker Compose. The production copy must be mode 0600 and never committed.
POSTGRES_DB=httpsms
POSTGRES_USER=httpsms
POSTGRES_PASSWORD=replace-with-a-long-random-password
NASAK_SMS_API_ENV_FILE=/opt/nasak-sms/shared/api.env
NASAK_SMS_API_PORT=3800
NASAK_SMS_WEB_PORT=3801

PUBLIC_API_BASE_URL=https://sms.nasak.ir/api
PUBLIC_APP_URL=https://sms.nasak.ir
PUBLIC_APP_NAME=Nasak SMS
PUBLIC_APP_GITHUB_URL=https://github.com/Nasak-ir/httpsms
PUBLIC_APP_DOCUMENTATION_URL=https://github.com/Nasak-ir/httpsms/blob/main/docs/NASAK_PRODUCTION.md
PUBLIC_APP_DOWNLOAD_URL=https://github.com/Nasak-ir/httpsms/releases/latest/download/NasakSms.apk

# Firebase Web SDK configuration. These identifiers are public by design, but
# still belong in the server configuration so environments remain portable.
FIREBASE_API_KEY=
FIREBASE_AUTH_DOMAIN=
FIREBASE_PROJECT_ID=
FIREBASE_STORAGE_BUCKET=
FIREBASE_MESSAGING_SENDER_ID=
FIREBASE_APP_ID=
FIREBASE_MEASUREMENT_ID=

CLOUDFLARE_TURNSTILE_SITE_KEY=
GIT_COMMIT=local
